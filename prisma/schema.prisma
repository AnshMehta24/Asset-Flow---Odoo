generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetCategoryFieldType {
  TEXT
  NUMBER
  DATE
  ENUM
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  RE_ALLOCATED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

enum AuditVerificationStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
}

model User {
  id                          String               @id @default(cuid())
  name                        String
  email                       String               @unique
  passwordHash                String
  role                        Role                 @default(EMPLOYEE)
  status                      UserStatus           @default(ACTIVE)
  departmentId                String?
  department                  Department?          @relation("DepartmentMembers", fields: [departmentId], references: [id])
  headOfDepartment            Department?          @relation("DepartmentHead")
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  registeredAssets            Asset[]              @relation("AssetRegisteredBy")
  allocationsReceived         Allocation[]         @relation("AllocationEmployee")
  allocationsGranted          Allocation[]         @relation("AllocationAllocatedBy")
  allocationReturnsRequested  Allocation[]         @relation("AllocationReturnRequestedBy")
  allocationReturnsApproved   Allocation[]         @relation("AllocationReturnApprovedBy")
  transfersRequested          TransferRequest[]    @relation("TransferRequester")
  transfersFrom               TransferRequest[]    @relation("TransferFromEmployee")
  transfersTo                 TransferRequest[]    @relation("TransferToEmployee")
  transfersApproved           TransferRequest[]    @relation("TransferApprover")
  bookings                    Booking[]            @relation("BookingBookedBy")
  maintenanceRequestsRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceRequestsApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditCyclesCreated          AuditCycle[]         @relation("AuditCreatedBy")
  auditCyclesClosed           AuditCycle[]         @relation("AuditClosedBy")
  auditAssignments            AuditAssignment[]
  auditItemsVerified          AuditItem[]          @relation("AuditVerifiedBy")
  notifications               Notification[]
  activityLogs                ActivityLog[]

  @@index([departmentId])
  @@index([role, status])
}

model Department {
  id                 String            @id @default(cuid())
  name               String            @unique
  code               String            @unique
  description        String?
  status             DepartmentStatus  @default(ACTIVE)
  parentId           String?
  parent             Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children           Department[]      @relation("DepartmentHierarchy")
  headId             String?           @unique
  head               User?             @relation("DepartmentHead", fields: [headId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  members            User[]            @relation("DepartmentMembers")
  assets             Asset[]
  allocations        Allocation[]      @relation("AllocationDepartment")
  bookings           Booking[]         @relation("BookingDepartment")
  auditCycles        AuditCycle[]
  transferRequestsTo TransferRequest[] @relation("TransferToDepartment")

  @@index([parentId])
  @@index([status])
}

model AssetCategory {
  id           String               @id @default(cuid())
  name         String               @unique
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  assets       Asset[]
  customFields AssetCategoryField[]
}

model Asset {
  id                  String                 @id @default(cuid())
  tagNumber           Int                    @unique @default(autoincrement()) // formatted as AF-0001 in the UI via formatSequenceNo()
  name                String
  description         String?
  serialNumber        String?                @unique
  qrCode              String?                @unique
  manufacturer        String?
  model               String?
  acquisitionDate     DateTime?              @db.Date
  acquisitionCost     Decimal?               @db.Decimal(12, 2)
  warrantyStartDate   DateTime?              @db.Date
  warrantyEndDate     DateTime?              @db.Date
  condition           AssetCondition         @default(GOOD)
  status              AssetStatus            @default(AVAILABLE)
  location            String?
  isBookable          Boolean                @default(false)
  notes               String?
  photoUrls           String[]
  documentUrls        String[]
  categoryId          String
  category            AssetCategory          @relation(fields: [categoryId], references: [id])
  departmentId        String?
  department          Department?            @relation(fields: [departmentId], references: [id])
  registeredById      String
  registeredBy        User                   @relation("AssetRegisteredBy", fields: [registeredById], references: [id])
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  customFieldValues   AssetCustomFieldValue[]

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([isBookable])
}

model AssetCategoryField {
  id          String                 @id @default(cuid())
  categoryId  String
  category    AssetCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key         String
  fieldType   AssetCategoryFieldType
  enumOptions String[]
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  assetValues AssetCustomFieldValue[]

  @@unique([categoryId, key])
  @@index([categoryId, sortOrder])
}

model AssetCustomFieldValue {
  id          String             @id @default(cuid())
  assetId      String
  asset        Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fieldId      String
  field        AssetCategoryField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  valueText    String?
  valueNumber  Decimal?           @db.Decimal(14, 4)
  valueDate    DateTime?          @db.Date
  valueEnum    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([assetId, fieldId])
  @@index([fieldId])
}

// Only one ACTIVE allocation may exist per asset at a time — this is the
// double-allocation guard. Declared here for documentation; enforced via a
// partial unique index added in a follow-up migration:
//   CREATE UNIQUE INDEX allocation_one_active_per_asset
//     ON "Allocation" ("assetId") WHERE status = 'ACTIVE';
model Allocation {
  id                   String            @id @default(cuid())
  status               AllocationStatus  @default(ACTIVE)
  assetId              String
  asset                Asset             @relation(fields: [assetId], references: [id])
  employeeId           String?
  employee             User?             @relation("AllocationEmployee", fields: [employeeId], references: [id])
  departmentId         String?
  department           Department?       @relation("AllocationDepartment", fields: [departmentId], references: [id])
  allocatedById        String
  allocatedBy          User              @relation("AllocationAllocatedBy", fields: [allocatedById], references: [id])
  allocatedAt          DateTime          @default(now())
  expectedReturnDate   DateTime?         @db.Date

  // return goes through a request -> approve step, same shape as transfers.
  // "pending return" = returnRequestedAt set but returnedAt still null.
  returnRequestedAt    DateTime?
  returnRequestedById  String?
  returnRequestedBy    User?             @relation("AllocationReturnRequestedBy", fields: [returnRequestedById], references: [id])
  returnConditionNotes String?
  returnApprovedById   String?
  returnApprovedBy     User?             @relation("AllocationReturnApprovedBy", fields: [returnApprovedById], references: [id])
  returnedAt           DateTime?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  transferRequests     TransferRequest[]

  @@index([assetId, status])
  @@index([employeeId])
  @@index([departmentId])
  @@index([status, expectedReturnDate])
}

model TransferRequest {
  id             String         @id @default(cuid())
  status         TransferStatus @default(REQUESTED)
  assetId        String
  asset          Asset          @relation(fields: [assetId], references: [id])
  allocationId   String?
  allocation     Allocation?    @relation(fields: [allocationId], references: [id])
  requestedById  String
  requestedBy    User           @relation("TransferRequester", fields: [requestedById], references: [id])
  fromEmployeeId String?
  fromEmployee   User?          @relation("TransferFromEmployee", fields: [fromEmployeeId], references: [id])
  toEmployeeId   String?
  toEmployee     User?          @relation("TransferToEmployee", fields: [toEmployeeId], references: [id])
  toDepartmentId String?
  toDepartment   Department?    @relation("TransferToDepartment", fields: [toDepartmentId], references: [id])
  reason         String?
  approvedById   String?
  approvedBy     User?          @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([assetId, status])
  @@index([requestedById])
}

// Overlap prevention is enforced in the app layer at write time (query
// existing UPCOMING/ONGOING bookings for the asset in [startTime, endTime)).
// For stronger guarantees, add a Postgres exclusion constraint later:
//   ALTER TABLE "Booking" ADD CONSTRAINT booking_no_overlap
//     EXCLUDE USING gist ("assetId" WITH =, tsrange("startTime","endTime") WITH &&)
//     WHERE (status IN ('UPCOMING','ONGOING'));
model Booking {
  id           String        @id @default(cuid())
  status       BookingStatus @default(UPCOMING)
  assetId      String
  asset        Asset         @relation(fields: [assetId], references: [id])
  bookedById   String
  bookedBy     User          @relation("BookingBookedBy", fields: [bookedById], references: [id])
  departmentId String?
  department   Department?   @relation("BookingDepartment", fields: [departmentId], references: [id])
  startTime    DateTime      @db.Timestamptz
  endTime      DateTime      @db.Timestamptz
  purpose      String?
  cancelledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([assetId, startTime, endTime])
  @@index([bookedById])
  @@index([status, startTime])
}

model MaintenanceRequest {
  id               String              @id @default(cuid())
  status           MaintenanceStatus   @default(PENDING)
  assetId          String
  asset            Asset               @relation(fields: [assetId], references: [id])
  raisedById       String
  raisedBy         User                @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  photoUrl         String?
  approvedById     String?
  approvedBy       User?               @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  rejectionReason  String?
  technicianName   String?
  scheduledDate    DateTime?           @db.Date // planned service date; drives "due in N days" reports
  resolvedAt       DateTime?
  resolutionNotes  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([assetId, status])
  @@index([status])
}

model AuditCycle {
  id           String            @id @default(cuid())
  name         String
  status       AuditCycleStatus  @default(PLANNED)
  departmentId String?
  department   Department?       @relation(fields: [departmentId], references: [id])
  location     String?
  startDate    DateTime          @db.Date
  endDate      DateTime          @db.Date
  createdById  String
  createdBy    User              @relation("AuditCreatedBy", fields: [createdById], references: [id])
  closedById   String?
  closedBy     User?             @relation("AuditClosedBy", fields: [closedById], references: [id])
  closedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  auditors     AuditAssignment[]
  items        AuditItem[]

  @@index([departmentId])
  @@index([status])
}

model AuditAssignment {
  id           String     @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditorId    String
  auditor      User       @relation(fields: [auditorId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([auditCycleId, auditorId])
}

model AuditItem {
  id               String                  @id @default(cuid())
  verification     AuditVerificationStatus @default(PENDING)
  auditCycleId     String
  auditCycle       AuditCycle              @relation(fields: [auditCycleId], references: [id])
  assetId          String
  asset            Asset                   @relation(fields: [assetId], references: [id])
  expectedLocation String?
  notes            String?
  verifiedById     String?
  verifiedBy       User?                   @relation("AuditVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([auditCycleId, assetId])
  @@index([verification])
}

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String
  link    String?
  isRead  Boolean          @default(false)
  userId  String
  user    User             @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String // e.g. "ASSET_ALLOCATED", "MAINTENANCE_APPROVED"
  entityType String // e.g. "Asset", "Booking"
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
